APP_NAME=FastAPI Auth Service
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
AUTO_CREATE_TABLES=true

DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fastapi_auth
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

RESET_TOKEN_EXPIRE_MINUTES=5
RESET_OTP_LENGTH=6

FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_URL_BASE=
PASSWORD_RESET_PATH=/reset-password

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_USE_TLS=true
